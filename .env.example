# ===================================================================
# YouTube Auto — 設定ファイル（ルート単一）
#
# このファイルをコピーして .env を作成し、必要な値を埋めてください:
#   Copy-Item .env.example .env
# install.ps1 を使う場合は自動生成されます。
#
# ここに書くのは「利用者が変えるもの（APIキー・モデル選択・ホスト依存値）」だけ。
# Dockerネットワーク内のサービスURLやコンテナ内パスなどの固定値は
# docker-compose.yml の environment: 側で定義済み（編集不要）。
# ===================================================================

# ─── LLM（脚本生成・検索ワード生成・キャラ設定など）───
# 使うプロバイダーのキーだけ設定すればよい
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
# xAI(Grok)。台本(xai/grok-4.3 等)と自由生成スタジオの画像(Grok Imagine)で共用。
GROK_API_KEY=
# 既定のLLM（LiteLLM形式）。OpenRouterは中間業者でマージンが乗るため、オリジナルAPIキーがある
# 以上そちらを優先する。既定は直接Anthropic APIのSonnet 5（OpenRouter非経由）。
# OpenRouterを使うのは無料モデルのテスト/利用に限定（有料のopenrouter/*指定は拒否される）。
DEFAULT_LLM_MODEL=anthropic/claude-sonnet-5
# ローカルLLM（Ollama, 任意）
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ─── research-agent 専用 Gemini キー（任意・推奨）───
# research-agent はラフ台本の蒸留で大きなコンテキストを使う。画像生成(NanoBanana)で使う
# Google アカウントとクォータを分けるため、このプロジェクト専用の Gemini キーをここに入れる。
# 別の Google アカウントで取得したキーを推奨。未設定なら上の GEMINI_API_KEY にフォールバックする。
RESEARCH_GEMINI_API_KEY=

# ─── ストック素材API（scrapping-agent）───
PEXELS_API_KEY=
PIXABAY_API_KEY=
# Vecteezy（任意。User ID + APIキー）
VECTEEZY_API_KEY=
VECTEEZY_USER_ID=

# ─── AI画像生成（NanoBanana / Gemini系。任意）───
# backend: auto（既定）| google | openrouter
NANOBANANA_BACKEND=auto
NANOBANANA_MODEL=gemini-2.5-flash-image
NANOBANANA_OR_MODEL=google/gemini-2.5-flash-image

# ─── AI画像生成（Cloudflare Workers AI。NanoBanana規約回避の外部フォールバック・任意）───
# オープンモデル(FLUX.2 klein 等)で骸骨/爆発/政治家など機微な題材を生成しやすい。
# 鍵(Workers AI権限)とAccount IDの2つが必須。モデル名は docker-compose.yml 側に固定。
# ※ research-agent もこの同じ鍵を協調利用する（Geminiのフォールバック頭脳 Llama 3.3 70B ＋
#    音声/動画ソースの書き起こし Whisper）。モデル名は docker-compose.yml の research-agent 側に固定。
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=

# ─── AI画像生成（Runware。規約回避の本命・任意）───
# オープンモデル(FLUX/SDXL)基盤で safety checker 無し/任意。有名人・政治家・故人など
# 実在人物の肖像も生成しやすい（Cloudflareが弾く題材の本命）。鍵1つでOK。
# モデルAIRは docker-compose.yml の RUNWARE_IMAGE_MODEL に固定。
RUNWARE_API_KEY=

# ─── AI音楽/効果音生成（Lyria。実験的・任意）───
# 自由生成タブのサウンド生成で使用。NanoBananaと同じ2系統バックエンド。
# backend: auto（既定）| google | openrouter
LYRIA_BACKEND=auto
# 既定=clip（短尺プレビュー）。長尺は lyria-3-pro-preview。
LYRIA_MODEL=lyria-3-clip-preview
LYRIA_OR_MODEL=google/lyria-3-clip-preview

# ─── 編集（editing-agent / DaVinci Resolve連携）───
# shared/ のホスト側絶対パス。Resolveがメディアを解決するのに使う。
# install.ps1 が実行ルートに合わせて自動設定する。手動時はこのルートの shared 絶対パスを入れる。
# 未設定でも他機能は動作する（OTIO出力時のみ必要）。
HOST_SHARED_DIR=
# OTIOのパス形式: file_uri（既定）/ windows（日本語パスでリンクできない場合）
OTIO_PATH_STYLE=file_uri
# 既定フレームレート（リクエストで上書き可: 24/30/60）
DEFAULT_FPS=30

# ─── TTS ───
# Irodori推論ステップ数（多いほど高品質・低速）
IRODORI_DEFAULT_NUM_STEPS=40
# TTSキャッシュ
TTS_CACHE_ENABLED=true

# ─── 共通 ───
LOG_LEVEL=INFO
